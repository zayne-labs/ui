{
	"name": "@zayne-labs/ui-root",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"license": "MIT",
	"scripts": {
		"build": "turbo run --filter=./packages/* build",
		"build:dev": "turbo run --filter=./packages/* build:dev",
		"build:docs": "turbo run --filter=./apps/docs build",
		"bump": "bumpp",
		"dev:dev": "turbo run --filter=./apps/dev dev",
		"dev:docs": "turbo run --filter=./apps/docs dev",
		"dev:react": "turbo run --filter=./packages/ui-react dev",
		"inspect:eslint-config": "pnpx @eslint/config-inspector@latest",
		"lint:attw": "turbo run --filter=./packages/* lint:attw",
		"lint:eslint": "turbo run lint:eslint",
		"lint:eslint:interactive": "turbo run --filter=./packages/* lint:eslint:interactive",
		"lint:eslint:root": "eslint . --max-warnings=0",
		"lint:eslint:root:interactive": "pnpx eslint-interactive@latest . --max-warnings=0 --fix",
		"lint:format": "turbo run lint:format",
		"lint:format:root": "prettier --write .",
		"lint:publint": "turbo run --filter=./packages/* lint:publint",
		"lint:size": "turbo run --filter=./packages/* lint:size",
		"lint:type-check": "turbo run --filter=./packages/* lint:type-check",
		"prepare": "husky",
		"release": "pnpm --filter=./packages/* release",
		"release:test": "pnpx pkg-pr-new publish ./packages/* --compact"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.2",
		"@eslint-react/eslint-plugin": "4.2.3",
		"@next/eslint-plugin-next": "16.2.3",
		"@types/node": "25.6.0",
		"@zayne-labs/eslint-config": "0.13.2",
		"@zayne-labs/prettier-config": "0.13.2",
		"@zayne-labs/tsconfig": "0.13.2",
		"bumpp": "10.4.1",
		"eslint": "10.2.0",
		"eslint-plugin-better-tailwindcss": "4.4.1",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"eslint-plugin-react-you-might-not-need-an-effect": "0.9.3",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"prettier": "3.8.3",
		"prettier-plugin-classnames": "0.10.1",
		"prettier-plugin-merge": "0.10.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"tailwindcss": "4.2.2",
		"turbo": "2.9.6",
		"typescript": "6.0.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	}
}
