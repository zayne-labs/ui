{
	"$schema": "https://turborepo.org/schema.json",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**", ".vercel"]
		},
		"build:docs": {},
		"build:dev": {},
		"lint:format": {},
		"lint:size": {},
		"lint:publint": {},
		"lint:eslint": {
			"cache": false
		},
		"knip": {
			"cache": true
		},
		"lint:type-check": {}
	}
}
